#!/usr/bin/env bash

# post-checkout hook
# arguments: <previous_head> <new_head> <checkout_type>

PREV=$1
NEW=$2
FLAG=$3

# Only proceed if it was a branch checkout
if [ "$FLAG" = "1" ]; then
    BRANCH=$(git rev-parse --abbrev-ref HEAD)
    
    # Check if branch name matches feature/TASK-*
    if [[ "$BRANCH" =~ ^feature/(TASK-[0-9]+) ]]; then
        TASK_ID="${BASH_REMATCH[1]}"
        echo "[Git Hook] Detected branch for $TASK_ID. Syncing to Notion..."
        
        SCRIPT_PATH="$(git rev-parse --show-toplevel)/.synapse/sync_notion_state.js"
        if [ -f "$SCRIPT_PATH" ]; then
            # Run in background to avoid blocking git checkout
            node "$SCRIPT_PATH" "$TASK_ID" "In Progress" &
        else
            echo "[Git Hook] Error: Notion sync script not found at $SCRIPT_PATH"
        fi
    fi
fi
